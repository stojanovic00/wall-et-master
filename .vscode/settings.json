{
  // Solidity Language Server Configuration
  "solidity.packageDefaultDependenciesContractsDirectory": "contracts",
  "solidity.packageDefaultDependenciesDirectory": "contracts/lib",
  "solidity.compileUsingRemoteVersion": "v0.8.30",
  "solidity.formatter": "forge",
  "solidity.defaultCompiler": "localNodeModule",

  // Solidity Remappings (matches foundry.toml)
  "solidity.remappings": [
    "@openzeppelin/=contracts/lib/openzeppelin-contracts/",
    "forge-std/=contracts/lib/forge-std/src/"
  ],

  // File associations
  "files.associations": {
    "*.sol": "solidity"
  },

  // Editor settings for Solidity
  "[solidity]": {
    "editor.defaultFormatter": "JuanBlanco.solidity",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },

  // LaTeX Workshop - force XeLaTeX + biber (required for fontspec + Cyrillic mapping + biblatex)
  "latex-workshop.formatting.latex": "latexindent",
  "[latex]": {
    "editor.formatOnSave": false,
    "editor.wordWrap": "on"
  },
  "latex-workshop.latex.tools": [
    {
      "name": "xelatex",
      "command": "xelatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ],
      "env": {}
    },
    {
      "name": "biber",
      "command": "biber",
      "args": ["%DOCFILE%"],
      "env": {}
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "XeLaTeX + Biber",
      "tools": ["xelatex", "biber", "xelatex", "xelatex"]
    }
  ],
  "latex-workshop.latex.recipe.default": "XeLaTeX + Biber",

  // Search settings (exclude build artifacts)
  "search.exclude": {
    "**/node_modules": true,
    "**/contracts/out": true,
    "**/contracts/cache": true,
    "**/contracts/lib": true,
    "**/extension/dist": true
  },

  // File watcher settings
  "files.watcherExclude": {
    "**/contracts/out/**": true,
    "**/contracts/cache/**": true,
    "**/contracts/lib/**": true,
    "**/extension/node_modules/**": true
  }
}
